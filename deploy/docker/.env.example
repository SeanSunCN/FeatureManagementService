# ============================================================
# Feature Management Service — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Database password (default: postgres)
DB_PASSWORD=postgres

# ClickHouse password (default: dev123)
CLICKHOUSE_PASSWORD=dev123

# Server public IP (for SDK report-back, leave empty if not needed)
HOST_IP=

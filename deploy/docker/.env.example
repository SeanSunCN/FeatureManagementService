# ============================================================
# Feature Management Service — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
# Password (default: postgres)
DB_PASSWORD=postgres

# --- Docker Compose cloud (self-contained) ---
# These are set in docker-compose.cloud.yml with sensible defaults
# but you can override them here for the .env file approach.

# --- Docker Compose NAS (original, infra_net) ---
# If using NAS mode, set hosts here:
# DB_HOST=dev_postgres
# DB_PORT=5432
# DB_USERNAME=postgres
# REDIS_HOST=dev_redis
# REDIS_PORT=6379
# KAFKA_HOST=dev_kafka
# KAFKA_PORT=9092
# CLICKHOUSE_HOST=dev_clickhouse
# CLICKHOUSE_PORT=8123

# --- ClickHouse ---
# Password (default: dev123 when access_management=1)
CLICKHOUSE_PASSWORD=dev123

# --- Server ---
# Server public IP (for SDK report-back, leave empty if not needed)
HOST_IP=

# --- Logging ---
# Log level (default: INFO)
LOG_LEVEL=INFO

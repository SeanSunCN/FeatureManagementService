{
  "__inputs": [],
  "__requires": [],
  "title": "Flag Usage Analytics â€?ClickHouse",
  "uid": "flag-usage-analytics",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "browser",
  "tags": ["flag-management", "clickhouse"],
  "panels": [
    {
      "title": "Total Evaluation Count by App",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "queryType": "sql",
        "rawSql": "SELECT recorded_at AS time, app_id AS metric, toFloat64(sum(eval_count)) AS value FROM flag.flag_hit_metrics WHERE $__timeFilter(recorded_at) GROUP BY time, metric ORDER BY time",
        "format": "table",
        "interval": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Hit Distribution by Flag Key (Last 24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "queryType": "sql",
        "rawSql": "SELECT flag_key AS metric, sum(hits) AS value FROM flag.flag_hit_metrics WHERE recorded_at >= now() - INTERVAL 24 HOUR GROUP BY metric ORDER BY value DESC",
        "format": "table",
        "interval": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal",
        "groupWidth": 80
      }
    },
    {
      "title": "Top Users by Evaluation Count (Last 24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "queryType": "sql",
        "rawSql": "SELECT user_id AS metric, count() AS value FROM flag.flag_audit_log WHERE recorded_at >= now() - INTERVAL 24 HOUR GROUP BY metric ORDER BY value DESC LIMIT 20",
        "format": "table",
        "interval": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "hidden" },
        "orientation": "horizontal",
        "groupWidth": 80
      }
    },
    {
      "title": "Enabled vs Disabled Evaluations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "queryType": "sql",
          "rawSql": "SELECT recorded_at AS time, 'enabled' AS metric, toFloat64(count()) AS value FROM flag.flag_audit_log WHERE enabled = 1 AND $__timeFilter(recorded_at) GROUP BY time ORDER BY time",
          "format": "table",
          "interval": ""
        },
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "queryType": "sql",
          "rawSql": "SELECT recorded_at AS time, 'disabled' AS metric, toFloat64(count()) AS value FROM flag.flag_audit_log WHERE enabled = 0 AND $__timeFilter(recorded_at) GROUP BY time ORDER BY time",
          "format": "table",
          "interval": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "sum", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Eval Latency (P50/P90/P99 from ClickHouse)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "queryType": "sql",
          "rawSql": "SELECT recorded_at AS time, 'p50' AS metric, toFloat64(quantile(0.50)(eval_cost_ns)) / 1000000 AS value FROM flag.flag_audit_log WHERE $__timeFilter(recorded_at) GROUP BY time ORDER BY time",
          "format": "table",
          "interval": ""
        },
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "queryType": "sql",
          "rawSql": "SELECT recorded_at AS time, 'p90' AS metric, toFloat64(quantile(0.90)(eval_cost_ns)) / 1000000 AS value FROM flag.flag_audit_log WHERE $__timeFilter(recorded_at) GROUP BY time ORDER BY time",
          "format": "table",
          "interval": ""
        },
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "queryType": "sql",
          "rawSql": "SELECT recorded_at AS time, 'p99' AS metric, toFloat64(quantile(0.99)(eval_cost_ns)) / 1000000 AS value FROM flag.flag_audit_log WHERE $__timeFilter(recorded_at) GROUP BY time ORDER BY time",
          "format": "table",
          "interval": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Evaluation Audit Log (Last 100)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "queryType": "sql",
        "rawSql": "SELECT recorded_at AS time, concat(app_id, ' / ', flag_key) AS label, concat('user=', user_id, ' enabled=', toString(enabled), ' cost_ns=', toString(eval_cost_ns), ' ip=', client_ip) AS line FROM flag.flag_audit_log ORDER BY recorded_at DESC LIMIT 100",
        "format": "logs",
        "interval": ""
      }]
    }
  ]
}

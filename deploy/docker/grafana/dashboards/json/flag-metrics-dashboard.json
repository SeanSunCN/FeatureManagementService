{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.1.0"},
    {"type": "datasource", "id": "clickhouse", "name": "ClickHouse", "version": "4.18.0"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "Row 1 - Macro Metrics (flag_hit_metrics)",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Evaluation Count per Flag (1m resolution)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"displayMode": "table", "stacking": {"mode": "none"}}},
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["mean","max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [{
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
        "queryType": "sql",
        "rawSql": "SELECT toStartOfMinute(recorded_at) AS time, flag_key AS metric, sum(eval_count) AS value FROM flag.flag_hit_metrics WHERE $__timeFilter(recorded_at) AND app_id IN ($app_id) GROUP BY time, metric ORDER BY time ASC",
        "refId": "A"
      }],
      "interval": "1m"
    },
    {
      "id": 3,
      "title": "True Hit Rate %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "connectNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["mean"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [{
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
        "queryType": "sql",
        "rawSql": "SELECT toStartOfMinute(recorded_at) AS time, flag_key AS metric, sum(hits) / nullIf(sum(eval_count), 0) AS value FROM flag.flag_hit_metrics WHERE $__timeFilter(recorded_at) AND app_id IN ($app_id) AND (hasAny(['All'], [$search_flag]) OR flag_key IN ($search_flag)) GROUP BY time, metric ORDER BY time ASC",
        "refId": "A"
      }],
      "interval": "1m"
    },
    {
      "id": 4,
      "title": "Top 10 Flags (last 1h)",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 9},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "continuous-GrYlRd"}},
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizHeight": 200,
        "reduceOptions": {
          "values": true,
          "fields": "/^value$/"
        }
      },
      "targets": [{
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
        "queryType": "sql",
        "format": "table",
        "rawSql": "SELECT flag_key AS metric, sum(eval_count) AS value FROM flag.flag_hit_metrics WHERE recorded_at >= now() - INTERVAL 1 HOUR GROUP BY flag_key ORDER BY value DESC LIMIT 10",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
      "id": 5,
      "panels": [],
      "title": "Row 2 - Audit Logs (flag_audit_log)",
      "type": "row"
    },
    {
      "id": 6,
      "title": "Macro Rule Distribution & Performance Analysis",
      "type": "table",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 18},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
      "fieldConfig": {
        "defaults": {
          "custom": {"displayMode": "auto", "align": "auto", "filterable": true},
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Traffic Share (%)"},
            "properties": [
              {"id": "custom.displayMode", "value": "lcd-gauge"},
              {"id": "min", "value": 0},
              {"id": "max", "value": 100},
              {"id": "unit", "value": "percent"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Avg Duration (ms)"},
            "properties": [{"id": "unit", "value": "ms"}]
          },
          {
            "matcher": {"id": "byName", "options": "P99 Duration (ms)"},
            "properties": [{"id": "unit", "value": "ms"}]
          }
        ]
      },
      "options": {
        "footer": {"countRows": true, "enablePagination": true},
        "showTypeIcons": false,
        "sortBy": [{"desc": true, "displayName": "Total Evaluations"}]
      },
      "targets": [{
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
        "queryType": "sql",
        "format": "table",
        "rawSql": "SELECT flag_key AS \"Feature Flag\", matched_rule AS \"Matched Rule\", count() AS \"Total Evaluations\", round(count() * 100.0 / sum(count()) over (partition by flag_key), 2) AS \"Traffic Share (%)\", round(avg(eval_cost_ns) / 1000000.0, 3) AS \"Avg Duration (ms)\", round(quantile(0.99)(eval_cost_ns) / 1000000.0, 3) AS \"P99 Duration (ms)\" FROM flag.flag_audit_log WHERE $__timeFilter(recorded_at) AND app_id IN ($app_id) AND (hasAny(['All'], [$search_flag]) OR flag_key IN ($search_flag)) GROUP BY flag_key, matched_rule ORDER BY \"Total Evaluations\" DESC LIMIT 100",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "title": "Eval Latency (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"displayMode": "table", "stacking": {"mode": "none"}}},
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["mean","max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [{
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
        "queryType": "sql",
        "rawSql": "SELECT toStartOfMinute(recorded_at) AS time, flag_key AS metric, avg(eval_cost_ns / 1000000.0) AS value FROM flag.flag_audit_log WHERE $__timeFilter(recorded_at) GROUP BY time, metric ORDER BY time ASC",
        "refId": "A"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["feature-flag", "clickhouse", "metrics"],
  "templating": {
    "list": [
      {
        "name": "app_id",
        "type": "query",
        "query": "SELECT DISTINCT app_id FROM flag.flag_hit_metrics ORDER BY app_id ASC",
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "allValue": "",
        "multi": true,
        "label": "App ID"
      },
      {
        "name": "search_flag",
        "type": "query",
        "query": "SELECT DISTINCT flag_key FROM flag.flag_audit_log ORDER BY flag_key ASC",
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse"},
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "allValue": "",
        "multi": false,
        "label": "Search Flag Key"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "title": "Feature Flag Metrics Dashboard",
  "uid": "flag-metrics-dashboard",
  "version": 2,
  "weekStart": ""
}
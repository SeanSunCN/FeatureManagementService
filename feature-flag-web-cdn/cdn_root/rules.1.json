{
  "version": 1,
  "flags": {
    "new-ui-portal": {
      "flagKey": "new-ui-portal",
      "enabled": true,
      "defaultServeValue": true,
      "rules": []
    },
    "dark-mode-v2": {
      "flagKey": "dark-mode-v2",
      "enabled": false,
      "defaultServeValue": false,
      "rules": [
        {
          "ruleName": "beta-users",
          "serveValue": true,
          "conditions": [
            {
              "attribute": "userId",
              "operator": "IN",
              "values": ["user-1001", "user-1002", "user-1003"]
            }
          ]
        }
      ]
    },
    "experimental-search": {
      "flagKey": "experimental-search",
      "enabled": true,
      "defaultServeValue": false,
      "rules": [
        {
          "ruleName": "rollout-10pct",
          "serveValue": true,
          "conditions": [
            {
              "attribute": "userId",
              "operator": "IN",
              "values": ["user-5001", "user-5002"]
            }
          ]
        }
      ]
    }
  }
}

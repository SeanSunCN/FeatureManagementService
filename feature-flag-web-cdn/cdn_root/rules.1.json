{
  "version" : 1,
  "flags" : {
    "flag-multi-rule" : {
      "flagKey" : "flag-multi-rule",
      "enabled" : true,
      "defaultServeValue" : false,
      "rules" : [ {
        "conditions" : [ {
          "values" : [ "US" ],
          "operator" : "EQUALS",
          "attribute" : "country"
        }, {
          "values" : [ "pro", "enterprise" ],
          "operator" : "IN",
          "attribute" : "plan"
        }, {
          "values" : [ "blocked-1", "blocked-2" ],
          "operator" : "NOT_IN",
          "attribute" : "userId"
        } ],
        "ruleName" : "US Pro users",
        "serveValue" : true
      }, {
        "conditions" : [ {
          "values" : [ "DE", "FR", "UK" ],
          "operator" : "IN",
          "attribute" : "country"
        }, {
          "values" : [ "true" ],
          "operator" : "EQUALS",
          "attribute" : "beta_tester"
        }, {
          "values" : [ "10" ],
          "operator" : "GREATER_THAN",
          "attribute" : "eval_count"
        } ],
        "ruleName" : "EU beta users",
        "serveValue" : true
      } ]
    }
  }
}
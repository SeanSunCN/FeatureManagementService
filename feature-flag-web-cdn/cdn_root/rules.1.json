{
  "version" : 1,
  "flags" : {
    "flag-multi-rule" : {
      "flagKey" : "flag-multi-rule",
      "enabled" : true,
      "defaultServeValue" : false,
      "rules" : [ {
        "serveValue" : true,
        "ruleName" : "US Pro users",
        "conditions" : [ {
          "attribute" : "country",
          "operator" : "EQUALS",
          "values" : [ "US" ]
        }, {
          "attribute" : "plan",
          "operator" : "IN",
          "values" : [ "pro", "enterprise" ]
        }, {
          "attribute" : "role",
          "operator" : "NOT_IN",
          "values" : [ "guest", "trial" ]
        } ]
      }, {
        "serveValue" : true,
        "ruleName" : "EU beta users",
        "conditions" : [ {
          "attribute" : "country",
          "operator" : "IN",
          "values" : [ "DE", "FR", "UK" ]
        }, {
          "attribute" : "beta_tester",
          "operator" : "EQUALS",
          "values" : [ "true" ]
        }, {
          "attribute" : "eval_count",
          "operator" : "GREATER_THAN",
          "values" : [ "10" ]
        } ]
      } ]
    }
  }
}